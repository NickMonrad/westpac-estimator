generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String
  password  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  projects  Project[]
  snapshots BacklogSnapshot[]
}

model GlobalResourceType {
  id            String           @id @default(cuid())
  name          String           @unique
  category      ResourceCategory
  description   String?
  isDefault     Boolean          @default(false)
  resourceTypes ResourceType[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
}

model Project {
  id          String        @id @default(cuid())
  name        String
  description String?
  customer    String?
  status      ProjectStatus @default(DRAFT)
  hoursPerDay Float         @default(7.6)
  startDate   DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  owner       User          @relation(fields: [ownerId], references: [id])
  ownerId     String
  epics       Epic[]
  resourceTypes ResourceType[]
  timelineEntries TimelineEntry[]
  snapshots   BacklogSnapshot[]
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  REVIEW
  COMPLETE
  ARCHIVED
}

model ResourceType {
  id           String              @id @default(cuid())
  name         String
  category     ResourceCategory
  count        Int                 @default(1)
  proposedName String?
  globalType   GlobalResourceType? @relation(fields: [globalTypeId], references: [id])
  globalTypeId String?
  project      Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId    String
  tasks        Task[]
  templateTasks TemplateTask[]
}

enum ResourceCategory {
  ENGINEERING
  GOVERNANCE
  PROJECT_MANAGEMENT
}

model Epic {
  id          String   @id @default(cuid())
  name        String
  description String?
  order       Int      @default(0)
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String
  features    Feature[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Feature {
  id             String         @id @default(cuid())
  name           String
  description    String?
  assumptions    String?
  order          Int            @default(0)
  epic           Epic           @relation(fields: [epicId], references: [id], onDelete: Cascade)
  epicId         String
  userStories    UserStory[]
  timelineEntry  TimelineEntry?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model UserStory {
  id                String   @id @default(cuid())
  name              String
  description       String?
  assumptions       String?
  order             Int      @default(0)
  appliedTemplateId String?
  feature           Feature  @relation(fields: [featureId], references: [id], onDelete: Cascade)
  featureId         String
  tasks             Task[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Task {
  id             String       @id @default(cuid())
  name           String
  description    String?
  assumptions    String?
  hoursEffort    Float        @default(0)
  durationDays   Float?
  order          Int          @default(0)
  userStory      UserStory    @relation(fields: [userStoryId], references: [id], onDelete: Cascade)
  userStoryId    String
  resourceType   ResourceType @relation(fields: [resourceTypeId], references: [id])
  resourceTypeId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

// Global feature templates (shared across all projects)
model FeatureTemplate {
  id          String         @id @default(cuid())
  name        String
  category    String?
  description String?
  tasks       TemplateTask[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model TemplateTask {
  id                String          @id @default(cuid())
  name              String
  order             Int             @default(0)
  hoursSmall        Float           @default(0)
  hoursMedium       Float           @default(0)
  hoursLarge        Float           @default(0)
  hoursExtraLarge   Float           @default(0)
  template          FeatureTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  templateId        String
  resourceType      ResourceType?   @relation(fields: [resourceTypeId], references: [id])
  resourceTypeId    String?
  resourceTypeName  String          // fallback name if no project-scoped resource type linked
}

model TimelineEntry {
  id            String   @id @default(cuid())
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId     String
  feature       Feature  @relation(fields: [featureId], references: [id], onDelete: Cascade)
  featureId     String   @unique
  startWeek     Int
  durationWeeks Int
  isManual      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model BacklogSnapshot {
  id          String   @id @default(cuid())
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String
  label       String?
  trigger     String   // 'manual' | 'csv_import' | 'template_apply'
  snapshot    Json
  createdAt   DateTime @default(now())
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdById String
}
