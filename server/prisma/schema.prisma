generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String
  password  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  projects  Project[]
  snapshots BacklogSnapshot[]
  documentTemplates DocumentTemplate[] @relation("DocumentTemplateOwner")
  generatedDocuments GeneratedDocument[] @relation("GeneratedDocumentUser")
}

model GlobalResourceType {
  id                 String           @id @default(cuid())
  name               String           @unique
  category           ResourceCategory
  description        String?
  defaultHoursPerDay Float?
  defaultDayRate     Float?
  isDefault          Boolean          @default(false)
  resourceTypes      ResourceType[]
  rateCardEntries    RateCardEntry[]
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
}

model Project {
  id          String        @id @default(cuid())
  name        String
  description String?
  customer    String?
  status      ProjectStatus @default(DRAFT)
  hoursPerDay Float         @default(7.6)
  bufferWeeks Int           @default(0)
  startDate   DateTime?
  taxRate      Float?    @default(10)
  taxLabel     String    @default("GST")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  owner       User          @relation(fields: [ownerId], references: [id])
  ownerId     String
  epics       Epic[]
  resourceTypes ResourceType[]
  timelineEntries TimelineEntry[]
  storyTimelineEntries StoryTimelineEntry[]
  snapshots   BacklogSnapshot[]
  overheads   ProjectOverhead[]
  discounts   ProjectDiscount[]
  weeklyDemandCache Json?
  generatedDocuments GeneratedDocument[]
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  REVIEW
  COMPLETE
  ARCHIVED
}

model ResourceType {
  id            String              @id @default(cuid())
  name          String
  category      ResourceCategory
  count         Int                 @default(1)
  hoursPerDay   Float?
  dayRate              Float?
  allocationMode       AllocationMode  @default(TIMELINE)
  allocationPercent    Float           @default(100)
  allocationStartWeek  Float?
  allocationEndWeek    Float?
  proposedName  String?
  globalType    GlobalResourceType? @relation(fields: [globalTypeId], references: [id])
  globalTypeId  String?
  project       Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId     String
  tasks         Task[]
  templateTasks TemplateTask[]
  overheads     ProjectOverhead[]
  namedResources NamedResource[]
  discounts      ProjectDiscount[]
}

model ProjectOverhead {
  id             String        @id @default(cuid())
  project        Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId      String
  name           String
  resourceType   ResourceType? @relation(fields: [resourceTypeId], references: [id])
  resourceTypeId String?
  type           OverheadType
  value          Float
  order          Int           @default(0)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

enum OverheadType {
  PERCENTAGE
  FIXED_DAYS
  DAYS_PER_WEEK
}

enum ResourceCategory {
  ENGINEERING
  GOVERNANCE
  PROJECT_MANAGEMENT
}

enum AllocationMode {
  EFFORT
  TIMELINE
  FULL_PROJECT
}

model Epic {
  id                String   @id @default(cuid())
  name              String
  description       String?
  assumptions       String?
  order             Int      @default(0)
  featureMode       String   @default("sequential")
  scheduleMode      String   @default("sequential")
  timelineStartWeek Int?
  isActive          Boolean  @default(true)
  project           Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId         String
  features          Feature[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Feature {
  id             String               @id @default(cuid())
  name           String
  description    String?
  assumptions    String?
  order          Int                  @default(0)
  isActive       Boolean              @default(true)
  epic           Epic                 @relation(fields: [epicId], references: [id], onDelete: Cascade)
  epicId         String
  userStories    UserStory[]
  timelineEntry  TimelineEntry?
  dependencies   FeatureDependency[]  @relation("FeatureDeps")
  dependents     FeatureDependency[]  @relation("FeatureDepsOn")
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
}

model FeatureDependency {
  feature      Feature  @relation("FeatureDeps", fields: [featureId], references: [id], onDelete: Cascade)
  featureId    String
  dependsOn    Feature  @relation("FeatureDepsOn", fields: [dependsOnId], references: [id], onDelete: Cascade)
  dependsOnId  String
  createdAt    DateTime @default(now())

  @@id([featureId, dependsOnId])
}

model StoryDependency {
  story       UserStory @relation("StoryDeps", fields: [storyId], references: [id], onDelete: Cascade)
  storyId     String
  dependsOn   UserStory @relation("StoryDepsOn", fields: [dependsOnId], references: [id], onDelete: Cascade)
  dependsOnId String
  createdAt   DateTime  @default(now())

  @@id([storyId, dependsOnId])
}

model StoryTimelineEntry {
  id            String    @id @default(cuid())
  story         UserStory @relation(fields: [storyId], references: [id], onDelete: Cascade)
  storyId       String    @unique
  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId     String
  startWeek     Float
  durationWeeks Float
  isManual      Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model UserStory {
  id                String   @id @default(cuid())
  name              String
  description       String?
  assumptions       String?
  order             Int      @default(0)
  isActive          Boolean  @default(true)
  appliedTemplateId String?
  appliedTemplate   FeatureTemplate? @relation(fields: [appliedTemplateId], references: [id])
  feature           Feature  @relation(fields: [featureId], references: [id], onDelete: Cascade)
  featureId         String
  tasks             Task[]
  dependencies      StoryDependency[]     @relation("StoryDeps")
  dependents        StoryDependency[]     @relation("StoryDepsOn")
  timelineEntry     StoryTimelineEntry?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Task {
  id             String       @id @default(cuid())
  name           String
  description    String?
  assumptions    String?
  hoursEffort    Float        @default(0)
  durationDays   Float?
  order          Int          @default(0)
  userStory      UserStory    @relation(fields: [userStoryId], references: [id], onDelete: Cascade)
  userStoryId    String
  resourceType   ResourceType? @relation(fields: [resourceTypeId], references: [id])
  resourceTypeId String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

// Global feature templates (shared across all projects)
model FeatureTemplate {
  id          String            @id @default(cuid())
  name        String            @unique
  category    String?
  description String?
  tasks       TemplateTask[]
  snapshots   TemplateSnapshot[]
  userStories UserStory[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model TemplateTask {
  id                String          @id @default(cuid())
  name              String
  order             Int             @default(0)
  hoursExtraSmall   Float           @default(0)
  hoursSmall        Float           @default(0)
  hoursMedium       Float           @default(0)
  hoursLarge        Float           @default(0)
  hoursExtraLarge   Float           @default(0)
  template          FeatureTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  templateId        String
  resourceType      ResourceType?   @relation(fields: [resourceTypeId], references: [id])
  resourceTypeId    String?
  resourceTypeName  String          // fallback name if no project-scoped resource type linked
}

model TimelineEntry {
  id            String   @id @default(cuid())
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId     String
  feature       Feature  @relation(fields: [featureId], references: [id], onDelete: Cascade)
  featureId     String   @unique
  startWeek     Float
  durationWeeks Float
  isManual      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model BacklogSnapshot {
  id          String   @id @default(cuid())
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String
  label       String?
  trigger     String   // 'manual' | 'csv_import' | 'template_apply'
  snapshot    Json
  createdAt   DateTime @default(now())
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdById String
}

model TemplateSnapshot {
  id          String          @id @default(cuid())
  template    FeatureTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  templateId  String
  label       String?
  trigger     String          // 'manual' | 'csv_import' | 'manual_edit'
  snapshot    Json
  createdAt   DateTime        @default(now())
}

model NamedResource {
  id             String       @id @default(cuid())
  resourceTypeId String
  resourceType   ResourceType @relation(fields: [resourceTypeId], references: [id], onDelete: Cascade)
  name           String
  startWeek      Int?
  endWeek        Int?
  allocationPct  Int          @default(100)
  allocationMode    AllocationMode  @default(EFFORT)
  allocationPercent Float           @default(100)
  allocationStartWeek Float?
  allocationEndWeek   Float?
  pricingModel   String       @default("ACTUAL_DAYS")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model RateCard {
  id        String         @id @default(cuid())
  name      String
  version   Int            @default(1)
  isDefault Boolean        @default(false)
  entries   RateCardEntry[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model RateCardEntry {
  id                   String             @id @default(cuid())
  rateCardId           String
  rateCard             RateCard           @relation(fields: [rateCardId], references: [id], onDelete: Cascade)
  globalResourceTypeId String
  globalResourceType   GlobalResourceType @relation(fields: [globalResourceTypeId], references: [id])
  dayRate              Float
}

model ProjectDiscount {
  id             String        @id @default(cuid())
  projectId      String
  project        Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  resourceTypeId String?
  resourceType   ResourceType? @relation(fields: [resourceTypeId], references: [id])
  type           String
  value          Float
  label          String
  order          Int           @default(0)
  createdAt      DateTime      @default(now())
}

enum DocumentTemplateType {
  SCOPE_DOC
  SOW
  PROPOSAL_DECK
}

model DocumentTemplate {
  id           String               @id @default(cuid())
  name         String
  type         DocumentTemplateType
  format       String               // 'docx' | 'pptx'
  customerName String?              // null = global; matches project.customer for scoping
  filePath     String               // relative path under uploads/templates/
  isDefault    Boolean              @default(false)
  owner        User                 @relation("DocumentTemplateOwner", fields: [ownerId], references: [id])
  ownerId      String
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  generatedDocs GeneratedDocument[]
}

model GeneratedDocument {
  id            String               @id @default(cuid())
  projectId     String
  project       Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  templateId    String?
  template      DocumentTemplate?    @relation(fields: [templateId], references: [id], onDelete: SetNull)
  type          DocumentTemplateType
  format        String               // 'pdf' | 'docx' | 'pptx'
  label         String
  filePath      String               // relative path under uploads/generated/
  generatedById String
  generatedBy   User                 @relation("GeneratedDocumentUser", fields: [generatedById], references: [id])
  createdAt     DateTime             @default(now())
}
